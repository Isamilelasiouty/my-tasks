rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedInAndVerified() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    function isOwner(resourceData) {
      return isSignedInAndVerified() && request.auth.uid == resourceData.ownerId;
    }
    function isOwnerOnCreate() {
      return isSignedInAndVerified() && request.auth.uid == request.resource.data.ownerId;
    }
    match /tasks/{taskId} {
      allow read, update, delete: if isOwner(resource.data);
      allow create: if isOwnerOnCreate();
    }
    match /projects/{projectId} {
      allow read, update, delete: if isOwner(resource.data);
      allow create: if isOwnerOnCreate();
    }
    match /clients/{clientId} {
      allow read, update, delete: if isOwner(resource.data);
      allow create: if isOwnerOnCreate();
    }
    match /seoSites/{siteId} {
      allow read, update, delete: if isOwner(resource.data);
      allow create: if isOwnerOnCreate();
    }
    match /seoTemplates/{templateId} {
      allow read, update, delete: if isOwner(resource.data);
      allow create: if isOwnerOnCreate();
    }
    match /goals/{goalId} {
      allow read, update, delete: if isOwner(resource.data);
      allow create: if isOwnerOnCreate();
    }
    match /notes/{noteId} {
      allow read, update, delete: if isOwner(resource.data);
      allow create: if isOwnerOnCreate();
    }
    match /references/{referenceId} {
      allow read, update, delete: if isOwner(resource.data);
      allow create: if isOwnerOnCreate();
    }
    match /timeEntries/{entryId} {
      allow read, update, delete: if isOwner(resource.data);
      allow create: if isOwnerOnCreate();
    }
    match /notifications/{notificationId} {
      allow read, update, delete: if isOwner(resource.data);
      allow create: if isOwnerOnCreate();
    }
    match /settings/{userId} {
      allow read, write: if isSignedInAndVerified() && request.auth.uid == userId;
    }
  }
}
